{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "declaration": false
  },
  "include": [
    "src/core/**/*.ts",
    "src/storage/**/*.ts",
    "src/routes.ts",
    "src/aggregator.ts",
    "src/node-entry.ts"
  ],
  "exclude": ["src/cf-entry.ts"]
}
